{
  "name": "ai-workroom",
  "productName": "AI作業場",
  "version": "0.1.0",
  "private": true,
  "description": "マルチAIオーケストレーター・デスクトップアプリ",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env ELECTRON_START_URL=http://127.0.0.1:5173 electron .\"",
    "build": "vite build",
    "start": "npm run build && electron .",
    "dist": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "latest",
    "@google/genai": "latest",
    "adm-zip": "^0.5.18",
    "openai": "latest",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "local.ai-workroom",
    "files": [
      "dist/**",
      "electron/**"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "artifactName": "AI作業場-portable.exe",
      "signAndEditExecutable": false
    }
  }
}
